Screen {
    align: center middle;
}

Button {
    width: 100%;
    height: 100%;
}

#frontpage {
    layout: grid;
    grid-size: 1;
    margin: 1 5;
}


#findpage {
    layout: grid;
    grid-size: 2;
    grid-rows: 1fr 2.5fr 1.5fr 2fr 3fr 1fr;

    margin: 1 5;

}

#search {
    column-span: 2;
}

#results {
    column-span: 2;
}

#back {
    column-span: 2;
    margin: 0 10;
}
